# SQLite database (relative to project root)
DATABASE_URL="file:./prisma/dev.db"

# Demo mode: true = use fixture extraction results, no API key needed
DEMO_MODE=true

# OpenAI-compatible LLM provider (used when DEMO_MODE=false)
# Examples:
#   DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1        LLM_MODEL=deepseek-chat
#   Zhipu GLM: LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4 LLM_MODEL=glm-4-flash
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
